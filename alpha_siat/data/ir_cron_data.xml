<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job to generate CUFD daily -->
        <record id="ir_cron_generate_daily_cufd" model="ir.cron">
            <field name="name">SIAT: Generate Daily CUFD</field>
            <field name="model_id" ref="model_alpha_siat_cufd"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_daily_cufd()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
            <!-- Run at 1:00 AM every day -->
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=1, minute=0, second=0)"/>
        </record>
    </data>
</odoo>