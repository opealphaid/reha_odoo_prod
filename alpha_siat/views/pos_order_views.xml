<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_order_form_siat" model="ir.ui.view">
        <field name="name">pos.order.form.siat</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Facturacion SIAT" invisible="not siat_xml_factura">
                    <field name="siat_cuf"/>
                    <field name="siat_xml_factura" widget="ace" options="{'mode': 'xml'}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>