<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record model="ir.ui.view" id="view_alpha_siat_actividad_documento_sector_list">
        <field name="name">alpha.siat.actividad.documento.sector.list</field>
        <field name="model">alpha.siat.actividad.documento.sector</field>
        <field name="arch" type="xml">
            <list>
                <field name="codigo_actividad"/>
                <field name="actividad_id"/>
                <field name="codigo_documento_sector"/>
                <field name="tipo_documento_sector"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="ultima_sincronizacion"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record model="ir.ui.view" id="view_alpha_siat_actividad_documento_sector_form">
        <field name="name">alpha.siat.actividad.documento.sector.form</field>
        <field name="model">alpha.siat.actividad.documento.sector</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_button" options="{'terminology': 'active'}"/>
                    </div>
                    <group>
                        <group string="Actividad">
                            <field name="codigo_actividad"/>
                            <field name="actividad_id" readonly="1"/>
                        </group>
                        <group string="Documento Sector">
                            <field name="codigo_documento_sector"/>
                            <field name="tipo_documento_sector"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="ultima_sincronizacion" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record model="ir.ui.view" id="view_alpha_siat_actividad_documento_sector_search">
        <field name="name">alpha.siat.actividad.documento.sector.search</field>
        <field name="model">alpha.siat.actividad.documento.sector</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo_actividad"/>
                <field name="tipo_documento_sector"/>
                <field name="actividad_id"/>
                <separator/>
                <filter string="Activas" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Inactivas" name="filter_inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Facturas" name="filter_facturas" domain="[('tipo_documento_sector', 'ilike', 'FAC')]"/>
                <filter string="Notas de Crédito" name="filter_nc" domain="[('tipo_documento_sector', 'ilike', 'NC')]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Actividad" name="group_actividad" context="{'group_by': 'codigo_actividad'}"/>
                    <filter string="Tipo Documento" name="group_tipo_doc" context="{'group_by': 'tipo_documento_sector'}"/>
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="action_alpha_siat_actividad_documento_sector">
        <field name="name">Actividades - Documentos Sector</field>
        <field name="res_model">alpha.siat.actividad.documento.sector</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay relaciones actividad-documento sincronizadas.
            </p>
            <p>
                Esta tabla relaciona las actividades económicas (CAEB) con los tipos de documentos/facturas sectoriales que pueden utilizar.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_alpha_siat_actividad_documento_sector"
              name="Actividades - Documentos"
              parent="menu_siat_sync_root"
              action="action_alpha_siat_actividad_documento_sector"
              sequence="20"/>
</odoo>