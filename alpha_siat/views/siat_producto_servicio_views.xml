<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record model="ir.ui.view" id="view_alpha_siat_producto_servicio_list">
        <field name="name">alpha.siat.producto.servicio.list</field>
        <field name="model">alpha.siat.producto.servicio</field>
        <field name="arch" type="xml">
            <list>
                <field name="codigo_actividad"/>
                <field name="actividad_id"/>
                <field name="codigo_producto"/>
                <field name="descripcion_producto"/>
                <field name="nandina_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="ultima_sincronizacion"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record model="ir.ui.view" id="view_alpha_siat_producto_servicio_form">
        <field name="name">alpha.siat.producto.servicio.form</field>
        <field name="model">alpha.siat.producto.servicio</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_button" options="{'terminology': 'active'}"/>
                    </div>
                    <group>
                        <group string="Actividad">
                            <field name="codigo_actividad"/>
                            <field name="actividad_id" readonly="1"/>
                        </group>
                        <group string="Producto/Servicio">
                            <field name="codigo_producto"/>
                            <field name="nandina_count"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="ultima_sincronizacion" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="descripcion_producto" widget="text"/>
                    </group>
                    <notebook>
                        <page string="Códigos NANDINA" attrs="{'invisible': [('nandina_count', '=', 0)]}">
                            <field name="nandina_ids">
                                <list editable="bottom">
                                    <field name="codigo_nandina"/>
                                    <field name="active" widget="boolean_toggle"/>
                                    <field name="ultima_sincronizacion" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record model="ir.ui.view" id="view_alpha_siat_producto_servicio_search">
        <field name="name">alpha.siat.producto.servicio.search</field>
        <field name="model">alpha.siat.producto.servicio</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo_actividad"/>
                <field name="codigo_producto"/>
                <field name="descripcion_producto"/>
                <field name="actividad_id"/>
                <separator/>
                <filter string="Con NANDINA" name="filter_con_nandina" domain="[('nandina_count', '>', 0)]"/>
                <filter string="Sin NANDINA" name="filter_sin_nandina" domain="[('nandina_count', '=', 0)]"/>
                <separator/>
                <filter string="Activos" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="filter_inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Actividad" name="group_actividad" context="{'group_by': 'codigo_actividad'}"/>
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="action_alpha_siat_producto_servicio">
        <field name="name">Productos y Servicios</field>
        <field name="res_model">alpha.siat.producto.servicio</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay productos o servicios sincronizados.
            </p>
            <p>
                Los productos y servicios se sincronizan desde SIAT y están asociados a actividades económicas. Incluyen códigos NANDINA cuando aplican.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_alpha_siat_producto_servicio"
              name="Productos y Servicios"
              parent="menu_siat_sync_root"
              action="action_alpha_siat_producto_servicio"
              sequence="40"/>
</odoo>