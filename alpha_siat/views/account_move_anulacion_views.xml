<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_anular_siat" model="ir.ui.view">
        <field name="name">account.move.form.anular.siat</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Agregar botón "Anular" en el header -->
            <xpath expr="//header" position="inside">
                <button name="action_anular_factura_siat"
                        string="Anular"
                        type="object"
                        class="btn-danger"
                        invisible="move_type not in ['out_invoice', 'out_refund'] or state != 'posted' or not siat_facturado or siat_anulado"
                        confirm="¿Está seguro que desea anular esta factura en SIAT? Esta acción no se puede deshacer y la factura será cancelada en Odoo."/>
            </xpath>

            <!-- Agregar campos invisibles para que funcione la condición invisible -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="siat_facturado" invisible="1"/>
                <field name="siat_anulado" invisible="1"/>
            </xpath>

        </field>
    </record>

</odoo>