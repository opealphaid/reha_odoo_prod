<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record model="ir.ui.view" id="view_alpha_siat_actividad_list">
        <field name="name">alpha.siat.actividad.list</field>
        <field name="model">alpha.siat.actividad</field>
        <field name="arch" type="xml">
            <list>
                <field name="codigo_caeb"/>
                <field name="descripcion"/>
                <field name="tipo_actividad"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="ultima_sincronizacion"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record model="ir.ui.view" id="view_alpha_siat_actividad_form">
        <field name="name">alpha.siat.actividad.form</field>
        <field name="model">alpha.siat.actividad</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_button" options="{'terminology': 'active'}"/>
                    </div>
                    <group>
                        <group>
                            <field name="codigo_caeb"/>
                            <field name="tipo_actividad"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="ultima_sincronizacion" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record model="ir.ui.view" id="view_alpha_siat_actividad_search">
        <field name="name">alpha.siat.actividad.search</field>
        <field name="model">alpha.siat.actividad</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo_caeb"/>
                <field name="descripcion"/>
                <filter string="Principal" name="filter_principal" domain="[('tipo_actividad', '=', 'P')]"/>
                <filter string="Secundaria" name="filter_secundaria" domain="[('tipo_actividad', '=', 'S')]"/>
                <separator/>
                <filter string="Activas" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Inactivas" name="filter_inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Tipo de Actividad" name="group_tipo" context="{'group_by': 'tipo_actividad'}"/>
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="action_alpha_siat_actividad">
        <field name="name">Actividades Económicas</field>
        <field name="res_model">alpha.siat.actividad</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay actividades económicas sincronizadas.
            </p>
            <p>
                Las actividades económicas (CAEB) se sincronizan desde SIAT y clasifican las actividades comerciales de la empresa.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_siat_sync_root"
              name="Sincronización"
              parent="menu_siat_root"
              sequence="40"/>

    <menuitem id="menu_alpha_siat_actividad"
              name="Actividades Económicas"
              parent="menu_siat_sync_root"
              action="action_alpha_siat_actividad"
              sequence="10"/>
</odoo>