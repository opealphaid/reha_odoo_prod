<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record model="ir.ui.view" id="view_alpha_siat_mensaje_servicio_list">
        <field name="name">alpha.siat.mensaje.servicio.list</field>
        <field name="model">alpha.siat.mensaje.servicio</field>
        <field name="arch" type="xml">
            <list>
                <field name="codigo_clasificador"/>
                <field name="descripcion"/>
                <field name="tipo_mensaje" widget="badge"
                       decoration-success="tipo_mensaje == 'success'"
                       decoration-danger="tipo_mensaje == 'error'"
                       decoration-warning="tipo_mensaje == 'warning'"
                       decoration-info="tipo_mensaje == 'info'"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="ultima_sincronizacion"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record model="ir.ui.view" id="view_alpha_siat_mensaje_servicio_form">
        <field name="name">alpha.siat.mensaje.servicio.form</field>
        <field name="model">alpha.siat.mensaje.servicio</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_button" options="{'terminology': 'active'}"/>
                    </div>
                    <group>
                        <group>
                            <field name="codigo_clasificador"/>
                            <field name="tipo_mensaje" widget="badge"
                                   decoration-success="tipo_mensaje == 'success'"
                                   decoration-danger="tipo_mensaje == 'error'"
                                   decoration-warning="tipo_mensaje == 'warning'"
                                   decoration-info="tipo_mensaje == 'info'"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="ultima_sincronizacion" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="descripcion" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record model="ir.ui.view" id="view_alpha_siat_mensaje_servicio_search">
        <field name="name">alpha.siat.mensaje.servicio.search</field>
        <field name="model">alpha.siat.mensaje.servicio</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo_clasificador"/>
                <field name="descripcion"/>
                <separator/>
                <filter string="Éxito" name="filter_success" domain="[('tipo_mensaje', '=', 'success')]"/>
                <filter string="Errores" name="filter_error" domain="[('tipo_mensaje', '=', 'error')]"/>
                <filter string="Advertencias" name="filter_warning" domain="[('tipo_mensaje', '=', 'warning')]"/>
                <filter string="Información" name="filter_info" domain="[('tipo_mensaje', '=', 'info')]"/>
                <separator/>
                <filter string="Activos" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="filter_inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Tipo de Mensaje" name="group_tipo" context="{'group_by': 'tipo_mensaje'}"/>
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="action_alpha_siat_mensaje_servicio">
        <field name="name">Mensajes de Servicios SIAT</field>
        <field name="res_model">alpha.siat.mensaje.servicio</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay mensajes de servicios sincronizados.
            </p>
            <p>
                Los mensajes de servicios contienen los códigos de respuesta y errores que SIAT puede devolver durante
                las operaciones.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_alpha_siat_mensaje_servicio"
              name="Mensajes de Servicios"
              parent="menu_siat_sync_root"
              action="action_alpha_siat_mensaje_servicio"
              sequence="30"/>
</odoo>