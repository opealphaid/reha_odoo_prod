<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record model="ir.ui.view" id="view_alpha_siat_pais_origen_list">
        <field name="name">alpha.siat.pais.origen.list</field>
        <field name="model">alpha.siat.pais.origen</field>
        <field name="arch" type="xml">
            <list>
                <field name="codigo_clasificador"/>
                <field name="descripcion"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="ultima_sincronizacion"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record model="ir.ui.view" id="view_alpha_siat_pais_origen_form">
        <field name="name">alpha.siat.pais.origen.form</field>
        <field name="model">alpha.siat.pais.origen</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="active" widget="boolean_button" options="{'terminology': 'active'}"/>
                    </div>
                    <group>
                        <group>
                            <field name="codigo_clasificador"/>
                            <field name="descripcion"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="ultima_sincronizacion" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <div class="alert alert-info" role="alert">
                            <strong>Uso:</strong> Los códigos de país se utilizan para declarar el origen de productos importados en las facturas.
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record model="ir.ui.view" id="view_alpha_siat_pais_origen_search">
        <field name="name">alpha.siat.pais.origen.search</field>
        <field name="model">alpha.siat.pais.origen</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo_clasificador"/>
                <field name="descripcion"/>
                <separator/>
                <filter string="Activos" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="filter_inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="action_alpha_siat_pais_origen">
        <field name="name">Países de Origen</field>
        <field name="res_model">alpha.siat.pais.origen</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay países sincronizados.
            </p>
            <p>
                Los códigos de país son utilizados para identificar el origen de productos importados en facturas de importación.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_alpha_siat_pais_origen"
              name="Países de Origen"
              parent="menu_siat_sync_root"
              action="action_alpha_siat_pais_origen"
              sequence="80"/>
</odoo>