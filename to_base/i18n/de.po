#: code:addons/to_base/models/to_base.py:0
#, python-format
msgid ""
"The `start_day_offset` passed to the method `period_iter` must be greater "
"than or equal to zero!"
msgstr ""
"Der an die Methode `period_iter` übergebene` start_day_offset` muss größer "
"oder gleich Null sein!"

#. module: to_base
#. odoo-python
#: code:addons/to_base/models/to_base.py:0
#, python-format
msgid "The given dt_from must be either date or datetime."
msgstr "Der angegebene dt_from muss entweder date oder datetime sein."

#. module: to_base
#. odoo-python
#: code:addons/to_base/models/to_base.py:0
#, python-format
msgid ""
"The given dt_start and dt_end passed into the method "
"`period_iter(period_name, dt_start, dt_end, start_day_offset)` must be in "
"the same type. This could be a programming error..."
msgstr ""
"Die angegebenen dt_start- und dt_end-Werte, die an die Methode "
"`period_iter(period_name, dt_start, dt_end, start_day_offset)` übergeben "
"werden, müssen vom gleichen Typ sein. Dies könnte ein Programmierfehler "
"sein..."

#. module: to_base
#. odoo-python
#: code:addons/to_base/models/to_base.py:0
#, python-format
msgid "The given dt_to must be either date or datetime."
msgstr "Das angegebene dt_to muss entweder date oder datetime."

#. module: to_base
#. odoo-python
#: code:addons/to_base/models/to_base.py:0
#, python-format
msgid ""
"The given period_start_date must be either date or datetime type. This "
"could be programming error..."
msgstr ""
"Das angegebene period_start_date muss entweder date oder datetime-Typ sein. "
"Dies könnte Programmierfehler sein ..."

#. module: to_base
#. odoo-python
