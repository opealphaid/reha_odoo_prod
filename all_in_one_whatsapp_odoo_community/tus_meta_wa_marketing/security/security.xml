<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="personal_whatsapp_marketing_history" model="ir.rule">
            <field name="name">Personal Whatsapp Marketing history</field>
            <field ref="model_whatsapp_messaging" name="model_id"/>
            <field name="domain_force">[('provider_id','=',user.provider_id.id),('create_uid','=',user.id),('company_ids','in', user.company_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('all_in_one_whatsapp_odoo_community.whatsapp_group_user'))]"/>
        </record>
    </data>
</odoo>