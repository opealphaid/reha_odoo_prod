<odoo>
    <record model="ir.ui.view" id="whatsapp_messaging_form_view">
        <field name="name">whatsapp.messaging.form</field>
        <field name="model">whatsapp.messaging</field>
        <field name="arch" type="xml">
            <form>
                <header style="min-height:31px;">
                    <button
                            name="put_in_queue"
                            type="object"
                            invisible="state != 'draft'"
                            class="oe_highlight"
                            string="Send Now"
                    />
                    <button
                            name="action_schedule_date"
                            type="object"
                            invisible="state != 'draft'"
                            class="btn-secondary"
                            string="Schedule"
                    />
                     <button name="action_test_whatsapp_marketing" type="object"
                            invisible="state != 'draft'" class="btn-secondary"
                            string="Test Template"/>
                    <button
                            name="cancel_mass_mailing"
                            type="object"
                            invisible="state == 'done'"
                            class="btn-secondary"
                            string="Cancel"
                    />

                    <field name="state" readonly="1" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                                name="action_view_documents_filtered"
                                id="button_view_inqueue"
                                type="object"
                                class="oe_stat_button"
                                context="{'state':'in queue'}"

                        >
                            <field
                                    name="inqueue_ratio"
                                    string="In Queue"
                                    widget="percentpie"
                            />
                        </button>

                        <button
                                name="action_view_documents_filtered"
                                id="button_view_sent"
                                type="object"
                                class="oe_stat_button"
                                context="{'state':'sent'}"
                        >
                            <field
                                    name="sent_ratio"
                                    string="Sent"
                                    widget="percentpie"
                            />
                        </button>

                        <button
                                name="action_view_documents_filtered"
                                id="button_view_delivered"
                                type="object"
                                class="oe_stat_button"
                                context="{'state':'delivered'}"
                        >
                            <field
                                    name="delivered_ratio"
                                    string="Delivered"
                                    widget="percentpie"
                            />
                        </button>

                        <button
                                name="action_view_documents_filtered"
                                id="button_view_received"
                                type="object"
                                class="oe_stat_button"
                                context="{'state':'received'}"

                        >
                            <field
                                    name="received_ratio"
                                    string="Received"
                                    widget="percentpie"
                            />
                        </button>

                        <button
                                name="action_view_documents_filtered"
                                id="button_view_read"
                                type="object"
                                class="oe_stat_button"
                                context="{'state':'read'}"

                        >
                            <field
                                    name="read_ratio"
                                    string="Read"
                                    widget="percentpie"
                            />
                        </button>

                        <button
                                name="action_view_documents_filtered"
                                id="button_view_fail"
                                type="object"
                                class="oe_stat_button"
                                context="{'state':'fail'}"
                        >
                            <field
                                    name="fail_ratio"
                                    string="Fail"
                                    widget="percentpie"
                            />
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="wa_messaging_model_id"/>
                        <field name="is_partner" invisible="1"/>
                        <field name="domain" invisible="is_partner == False"/>
                        <field name="schedule_date" invisible="1"/>
                        <field
                                name="partner_ids"
                                widget="many2many_tags"
                                invisible="domain == True or is_partner == False"
                        />
                        <field
                                name="whatsapp_messaging_lists_ids"
                                widget="many2many_tags"
                                invisible="is_partner == True"
                        />
                        <field
                                name="wa_messaging_domain"
                                widget="domain"
                                invisible="is_partner == False or domain == False"
                                options="{'model': 'res.partner'}"
                        >
                        </field>
                        <field name="company_ids" widget="many2many_tags"/>
                        <field name="is_cron_run" readonly="1"/>
                        <field name="user_id" invisible="1"/>
                    </group>
                    <group>
                        <group>
                            <field
                                    name="provider_id"
                                    required="1"
                                    domain="[('company_id','in', company_ids),('id','in',allowed_provider_ids)]"
                            />
                            <field name="allowed_provider_ids" invisible="1"/>
                        </group>
                        <group>
                            <field
                                    name="template_id"
                                    domain="[('provider_id','=',provider_id)]"
                            />
                        </group>
                    </group>

                    <group col="4">
                        <field
                                name="attachment_ids"
                                widget="many2many_binary"
                                string="Attach a file"
                                nolabel="1"
                                colspan="2"
                        />
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <group>
                                <!--                                <field name="body_html" widget="html" options="{'style-inline': true, 'codeview': true }" nolabel="1"/>-->
                                <field
                                        name="body_html"
                                        widget="html"
                                        nolabel="1"
                                        colspan="2"
                                />
                            </group>
                        </page>
                        <page string="Whatsapp Messages" name="history">
                            <!--                            <group>-->
                            <field name="mail_history_ids">
                                <list>
                                    <field name="provider_id"/>
                                    <field name="date"/>
                                    <field name="author_id"/>
                                    <field name="partner_id"/>
                                    <field name="phone"/>
                                    <field name="message"/>
                                    <field
                                            name="attachment_ids"
                                            widget="many2many_tags"
                                    />
                                    <field name="type"/>
                                    <field name="fail_reason"/>
                                </list>
                            </field>
                            <!--                            </group>-->
                        </page>
                        <page string="Contact Message History" name="contact_history">
                            <field name="marketing_contact_mes_history_ids">
                                <list>
                                    <field name="phone"/>
                                    <field name="contact_whatsapp_history_ids"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="phone" readonly="1"/>
                                    </group>
                                    <field
                                            name="contact_whatsapp_history_ids"
                                            widget="one2many"
                                            nolabel="1"
                                    >
                                        <list>
                                            <field name="provider_id"/>
                                            <field name="date"/>
                                            <field name="author_id"/>
                                            <field name="partner_id"/>
                                            <field name="phone"/>
                                            <field name="message"/>
                                            <field
                                                    name="attachment_ids"
                                                    widget="many2many_tags"
                                            />
                                            <field name="type"/>
                                            <field name="fail_reason"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                    <chatter/>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="whatsapp_messaging_list_view">
        <field name="name">whatsapp.messaging.list</field>
        <field name="model">whatsapp.messaging</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc">
                <field name="name"/>
                <!--                <field name="partner_ids" widget="many2many_tags"/>-->
                <!--                <field name="whatsapp_messaging_lists_ids" widget="many2many_tags"/>-->
                <field
                        name="inqueue_ratio"
                        class="d-flex align-items-center ps-0 ps-lg-5"
                        widget="progressbar"
                        string="In Queue (%)"
                        avg="Average"
                />
                <field
                        name="sent_ratio"
                        class="d-flex align-items-center ps-0 ps-lg-5"
                        widget="progressbar"
                        string="Sent (%)"
                        avg="Average"
                />
                <field
                        name="delivered_ratio"
                        class="d-flex align-items-center ps-0 ps-lg-5"
                        widget="progressbar"
                        string="Delivered (%)"
                        avg="Average"
                />
                <field
                        name="received_ratio"
                        class="d-flex align-items-center ps-0 ps-lg-5"
                        widget="progressbar"
                        string="Received (%)"
                        avg="Average"
                />
                <field
                        name="read_ratio"
                        class="d-flex align-items-center ps-0 ps-lg-5"
                        widget="progressbar"
                        string="Read (%)"
                        avg="Average"
                />
                <field
                        name="fail_ratio"
                        class="d-flex align-items-center ps-0 ps-lg-5"
                        widget="progressbar"
                        string="Fail (%)"
                        avg="Average"
                />
                <field name="wa_messaging_model_id"/>
            </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="whatsapp_messaging_action">
        <field name="name">Whatsapp Marketing</field>
        <field name="res_model">whatsapp.messaging</field>
        <field name="view_mode">list,form</field>
    </record>
    <record model="ir.actions.act_window" id="whatsapp_messaging_run_schedule_action">
        <field name="name">Whatsapp Marketing Schedule Action</field>
        <field name="res_model">ir.cron</field>
        <field name="domain">[('model_id.model', '=', 'whatsapp.messaging')]</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
            id="whatsapp_marketing_menu"
            name="Whatsapp Marketing"
            web_icon="all_in_one_whatsapp_odoo_community,static/tus_meta_wa_marketing/static/description/icon.png"
            groups="all_in_one_whatsapp_odoo_community.whatsapp_group_user"
    />
    <menuitem
            id="whatsapp_messaging_sub_menu"
            name="Whatsapp Marketing"
            parent="whatsapp_marketing_menu"
            action="whatsapp_messaging_action"
    />
    <menuitem id="whatsapp_messaging_schedule_action" name="Schedule Marketing" parent="whatsapp_marketing_menu"
              action="whatsapp_messaging_run_schedule_action" sequence="20"/>
</odoo>
