    <menuitem id="menu_rehalife_cities"
              name="Ciudades"
              parent="menu_rehalife_sync_root"
              sequence="10"
              action="action_rehalife_city"/>

    <!-- Sincronización Masiva -->
    <menuitem id="menu_rehalife_sync_wizard"
              name="Sincronizacion Masiva"
              parent="menu_rehalife_sync_root"
              sequence="20"
              action="action_rehalife_sync_wizard"/>

    <!-- Importar Reservas Completadas (respaldo) -->
    <menuitem id="menu_rehalife_import_reservations"
              name="Importar Reservas Completadas"
