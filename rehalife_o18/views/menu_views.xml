<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Menú raíz -->
    <menuitem id="menu_rehalife_root"
              name="Rehalife"
              sequence="50"/>

    <!-- Reservas -->
    <menuitem id="menu_rehalife_reservations"
              name="Reservas"
              parent="menu_rehalife_root"
              sequence="5"
              action="action_rehalife_reservations"/>

    <!-- Contactos (todos) -->
    <menuitem id="menu_rehalife_contacts"
              name="Contactos"
              parent="menu_rehalife_root"
              sequence="10"
              action="action_rehalife_contacts_all"/>

    <!-- Configuración -->
    <menuitem id="menu_rehalife_settings"
              name="Configuracion"
              parent="menu_rehalife_root"
              sequence="30"
              action="action_rehalife_config"/>

